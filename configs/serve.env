# Legacy environment variables consumed by configs/serve.yaml.
#
# Prefer editing configs/serve.yaml directly. Keep this file for deployments
# that source environment variables before launching scripts.

RAG_ASR_ROOT=/path/to/RAG-ASR

# Model artifacts
RAG_ASR_BASE_MODEL=${RAG_ASR_ROOT}/checkpoints/base/amphion_1.7b_merged
RAG_ASR_ADAPTER=${RAG_ASR_BASE_MODEL}/hotword_adapter/best_adapter.pt
RAG_ASR_HOTWORD_POOL=/path/to/hotword_pool.txt

# Retrieval parameters
RAG_ASR_TOP_K=50
RAG_ASR_EMBED_DIM=512
RAG_ASR_ADAPTER_HIDDEN_DIM=512
RAG_ASR_DEVICE=cuda
RAG_ASR_CACHE_DIR=${RAG_ASR_ROOT}/_retrieve_cache

# Triton runtime
RAG_ASR_TRITON_MODEL_REPO=${RAG_ASR_ROOT}/triton
# Optional override. By default serve.yaml uses ${CONDA_PREFIX}/../triton-exec
# after scripts/start_triton.sh activates the triton conda env.
# RAG_ASR_TRITON_EXEC_ENV=/path/to/miniconda/envs/triton-exec
RAG_ASR_TRITON_HTTP_PORT=8000
RAG_ASR_TRITON_GRPC_PORT=8001

# Local HTTP debug service
RAG_ASR_HTTP_PORT=8080
