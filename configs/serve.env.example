# RAG-ASR service configuration example.
#
# Copy this file to configs/serve.env and adjust paths for the current machine.
# The existing scripts still provide their own defaults; this file documents the
# intended single source of truth for future deploy/infer entry points.

RAG_ASR_ROOT=/chenmingjie/lx/RAG-ASR

# Model artifacts
RAG_ASR_BASE_MODEL=${RAG_ASR_ROOT}/checkpoints/base/amphion_1.7b_merged
RAG_ASR_ADAPTER=${RAG_ASR_ROOT}/checkpoints/adapters/amphion-1.7b_retrieval_v1.2/best_adapter.pt
RAG_ASR_HOTWORD_POOL=/chenmingjie/lx/data/hotword/zh/zh-10k.txt

# Retrieval parameters
RAG_ASR_TOP_K=50
RAG_ASR_EMBED_DIM=512
RAG_ASR_ADAPTER_HIDDEN_DIM=512
RAG_ASR_DEVICE=cuda
RAG_ASR_CACHE_DIR=${RAG_ASR_ROOT}/_retrieve_cache

# Triton runtime
RAG_ASR_TRITON_MODEL_REPO=${RAG_ASR_ROOT}/triton
RAG_ASR_TRITON_EXEC_ENV=/ai_sds_wuzz/MODELS/miniconda3/envs/triton-exec
RAG_ASR_TRITON_HTTP_PORT=8000
RAG_ASR_TRITON_GRPC_PORT=8001

# Local HTTP debug service
RAG_ASR_HTTP_PORT=8080
